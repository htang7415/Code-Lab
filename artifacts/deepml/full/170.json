{"tinygrad_test_cases":[{"test":"from tinygrad.tensor import Tensor\nimport numpy as np\nimport math\n\ndef newton_schulz5(G: Tensor, steps: int = 5, eps: float = 1e-7) -> Tensor:\n    a, b, c = 3.4445, -4.7750, 2.0315\n    X = G\n    fro_norm = (X * X).sum().sqrt()\n    X = X / (fro_norm + eps)\n    transposed = False\n    if X.shape[0] > X.shape[1]:\n        X = X.T\n        transposed = True\n    for _ in range(steps):\n        A = X @ X.T\n        X = a * X + (b * A + c * (A @ A)) @ X\n    if transposed:\n        X = X.T\n    return X\n\ndef muon_step(theta: Tensor, B: Tensor, grad: Tensor, eta: float, mu: float, ns_steps: int = 5, eps: float = 1e-7) -> tuple:\n    B_new = mu * B + grad\n    O = newton_schulz5(B_new, steps=ns_steps, eps=eps)\n    fro_norm = (B_new * B_new).sum().sqrt()\n    scale_num = math.sqrt(theta.shape[0] * theta.shape[1])\n    scale = scale_num / (fro_norm + eps)\n    theta_new = theta - eta * scale * O\n    return theta_new, B_new\n\ntheta = Tensor(np.eye(2, dtype=np.float32))\nB = Tensor(np.zeros((2,2), dtype=np.float32))\ngrad = Tensor(np.ones((2,2), dtype=np.float32))\neta = 0.1\nmu = 0.9\ntheta_new, B_new = muon_step(theta, B, grad, eta, mu, ns_steps=2)\nresult = [[round(float(x), 3) for x in row] for row in theta_new.numpy()]\nprint(result)","expected_output":"[[0.944, -0.056], [-0.056, 0.944]]"},{"test":"from tinygrad.tensor import Tensor\nimport numpy as np\nimport math\n\ndef newton_schulz5(G: Tensor, steps: int = 5, eps: float = 1e-7) -> Tensor:\n    a, b, c = 3.4445, -4.7750, 2.0315\n    X = G\n    fro_norm = (X * X).sum().sqrt()\n    X = X / (fro_norm + eps)\n    transposed = False\n    if X.shape[0] > X.shape[1]:\n        X = X.T\n        transposed = True\n    for _ in range(steps):\n        A = X @ X.T\n        X = a * X + (b * A + c * (A @ A)) @ X\n    if transposed:\n        X = X.T\n    return X\n\ndef muon_step(theta: Tensor, B: Tensor, grad: Tensor, eta: float, mu: float, ns_steps: int = 5, eps: float = 1e-7) -> tuple:\n    B_new = mu * B + grad\n    O = newton_schulz5(B_new, steps=ns_steps, eps=eps)\n    fro_norm = (B_new * B_new).sum().sqrt()\n    scale_num = math.sqrt(theta.shape[0] * theta.shape[1])\n    scale = scale_num / (fro_norm + eps)\n    theta_new = theta - eta * scale * O\n    return theta_new, B_new\n\ntheta = Tensor(np.eye(6, dtype=np.float32))\nB = Tensor(np.zeros((6,6), dtype=np.float32))\ngrad = Tensor(np.ones((6,6), dtype=np.float32))\neta = 0.7\nmu = 0.95\ntheta_new, B_new = muon_step(theta, B, grad, eta, mu, ns_steps=2)\nresult = [[round(float(x), 2) for x in row] for row in theta_new.numpy()]\nprint(result)","expected_output":"[[0.87, -0.13, -0.13, -0.13, -0.13, -0.13], [-0.13, 0.87, -0.13, -0.13, -0.13, -0.13], [-0.13, -0.13, 0.87, -0.13, -0.13, -0.13], [-0.13, -0.13, -0.13, 0.87, -0.13, -0.13], [-0.13, -0.13, -0.13, -0.13, 0.87, -0.13], [-0.13, -0.13, -0.13, -0.13, -0.13, 0.87]]"},{"test":"from tinygrad.tensor import Tensor\nimport numpy as np\nimport math\n\ndef newton_schulz5(G: Tensor, steps: int = 5, eps: float = 1e-7) -> Tensor:\n    a, b, c = 3.4445, -4.7750, 2.0315\n    X = G\n    fro_norm = (X * X).sum().sqrt()\n    X = X / (fro_norm + eps)\n    transposed = False\n    if X.shape[0] > X.shape[1]:\n        X = X.T\n        transposed = True\n    for _ in range(steps):\n        A = X @ X.T\n        X = a * X + (b * A + c * (A @ A)) @ X\n    if transposed:\n        X = X.T\n    return X\n\ndef muon_step(theta: Tensor, B: Tensor, grad: Tensor, eta: float, mu: float, ns_steps: int = 5, eps: float = 1e-7) -> tuple:\n    B_new = mu * B + grad\n    O = newton_schulz5(B_new, steps=ns_steps, eps=eps)\n    fro_norm = (B_new * B_new).sum().sqrt()\n    scale_num = math.sqrt(theta.shape[0] * theta.shape[1])\n    scale = scale_num / (fro_norm + eps)\n    theta_new = theta - eta * scale * O\n    return theta_new, B_new\n\ntheta = Tensor(np.eye(4, dtype=np.float32))\nB = Tensor(np.zeros((4,4), dtype=np.float32))\ngrad = Tensor(np.eye(4, dtype=np.float32))\neta = 0.01\nmu = 0.95\ntheta_new, B_new = muon_step(theta, B, grad, eta, mu, ns_steps=1)\nresult = [[round(float(x), 3) for x in row] for row in theta_new.numpy()]\nprint(result)","expected_output":"[[0.976, 0.0, 0.0, 0.0], [0.0, 0.976, 0.0, 0.0], [0.0, 0.0, 0.976, 0.0], [0.0, 0.0, 0.0, 0.976]]"}],"description":"","embedding":[-0.03869554400444031,-0.043908458203077316,0.021173829212784767,0.02287827804684639,0.02278829924762249,0.013483192771673203,0.019703326746821404,0.0027120269369333982,-0.05586638301610947,-0.059602610766887665,0.019704047590494156,-0.04527230188250542,-0.01834818720817566,0.02258928306400776,0.010135424323379993,0.03807946667075157,0.011433827690780163,-0.012783768586814404,-0.06273512542247772,0.043214570730924606,-0.005755343474447727,-0.04577578231692314,0.05945851653814316,0.03605939820408821,0.01347894873470068,-0.020185669884085655,0.05779363960027695,-0.015553484670817852,-0.027987346053123474,-0.0014698283048346639,-0.0024835383519530296,0.01579010859131813,-0.012526190839707851,-0.018762513995170593,0.03403836488723755,0.02781807631254196,-0.02574557438492775,0.038089849054813385,-0.015526860021054745,0.02335154265165329,0.007388521451503038,-0.0059198071248829365,-0.019887281581759453,0.0021906860638409853,0.0079689035192132,0.010716683231294155,-0.005001334473490715,0.04442710429430008,-0.0450359508395195,-0.07474065572023392,-0.06079341843724251,0.04494522511959076,0.02091497741639614,-0.03062058426439762,0.006836616899818182,0.038308314979076385,0.006656442303210497,-0.04952402785420418,-0.002399669960141182,-0.03126686066389084,-0.017329618334770203,0.012853093445301056,-0.013892710208892822,0.02169952169060707,0.021708350628614426,-0.02142966166138649,0.02973879501223564,0.04836955666542053,-0.07113207131624222,-0.08283869922161102,-0.02426845394074917,0.004279229324311018,-0.008825941011309624,-0.01822308450937271,-0.0035338045563548803,-0.017506614327430725,0.03960156813263893,0.005911311600357294,0.040360212326049805,0.01791285164654