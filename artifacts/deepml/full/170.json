rthogonalization/preconditioning\n    pass\n\ndef muon_step(theta, B, grad, eta, mu, ns_steps=5, eps=1e-7):\n    \"\"\"\n    theta: np.ndarray, shape (M, N)\n    B: np.ndarray, shape (M, N)\n    grad: np.ndarray, shape (M, N)\n    eta: float (learning rate)\n    mu: float (momentum coefficient)\n    ns_steps: int (Newton-Schulz steps)\n    eps: float (numerical stability)\n    Returns: updated theta, updated B\n    \"\"\"\n    # Implement the Muon optimizer update step\n    pass\n","title":"Muon Optimizer Step with Matrix Preconditioning","createdAt":"January 13, 2026 at 12:28:40 PM UTC-0500","contributor":[{"profile_link":"https://github.com/moe18","name":"Moe Chabot"}],"pytorch_test_cases":[{"test":"import torch\nimport numpy as np\ntheta = torch.eye(2)\nB = torch.zeros((2, 2))\ngrad = torch.ones((2, 2))\neta = 0.1\nmu = 0.9\ntheta_new, B_new = muon_step(theta, B, grad, eta, mu, ns_steps=2)\nresult = [[round(float(x), 3) for x in row] for row in theta_new.numpy()]\nprint(result)","expected_output":"[[0.944, -0.056], [-0.056, 0.944]]"},{"test":"import torch\nimport numpy as np\ntheta = torch.eye(6)\nB = torch.zeros((6, 6))\ngrad = torch.ones((6, 6))\neta = 0.7\nmu = 0.95\ntheta_new, B_new = muon_step(theta, B, grad, eta, mu, ns_steps=2)\nresult = [[round(float(x), 2) for x in row] for row in theta_new.numpy()]\nprint(result)","expected_output":"[[0.87, -0.13, -0.13, -0.13, -0.13, -0.13], [-0.13, 0.87, -0.13, -0.13, -0.13, -0.13], [-0.13, -0.13, 0.87, -0.13, -0.13, -0.13], [-0.13, -0.13, -0.13, 0.87, -0.13, -0.13], [-0.13, -0.13, -0.13, -0.13, 0.87, -0.13], [-0.13, -0.13, -0.13, -0.13, -0.13, 0.87]]"},{"test":"import torch\nimport numpy as np\ntheta = torch.eye(4)\nB = torch.zeros((4, 4))\ngrad = torch.eye(4)\neta = 0.01\nmu = 0.95\ntheta_new, B_new = muon_step(theta, B, grad, eta, mu, ns_steps=1)\nresult = [[round(float(x), 3) for x in row] for row in theta_new.numpy()]\nprint(result)","expected_output":"[[0.976, 0.0, 0.0, 0.0], [0.0, 0.976, 0.0, 0.0], [0.0, 0.0, 0