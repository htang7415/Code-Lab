nygrad_starter_code":"","test_cases":[{"test":"import numpy as np\ndef gradient_function(x):\n    if isinstance(x, np.ndarray):\n        n = len(x)\n        return x - np.arange(n)\n    else:\n        return x - 0\nprint(nag_optimizer(1., gradient_function, 0.5, 0.01, 0.9))","expected_output":"(0.5445, 0.4555)"},{"test":"import numpy as np\ndef gradient_function(x):\n    if isinstance(x, np.ndarray):\n        n = len(x)\n        return x - np.arange(n)\n    else:\n        return x - 0\nprint(nag_optimizer(np.array([1.0, 2.0]), gradient_function, np.array([0.5, 1.0]), 0.01, 0.9))","expected_output":"(array([0.5445, 1.099]), array([0.4555, 0.901]))"}],"difficulty":"easy","pytorch_difficulty":"easy","video":"","likes":"0","dislikes":"0","example":{"input":"parameter = 1.0, grad_fn = lambda x: x, velocity = 0.1","output":"(0.9009, 0.0991)","reasoning":"The Nesterov Accelerated Gradient optimizer computes updated values for the parameter and velocity using a look-ahead approach. With input values parameter=1.0, grad_fn=lambda x: x, and velocity=0.1, the updated parameter becomes 0.9009 and the updated velocity becomes 0.0991."},"category":"Deep Learning","starter_code":"import numpy as np\n\ndef nag_optimizer(parameter, grad_fn, velocity, learning_rate=0.01, momentum=0.9):\n    \"\"\"\n    Update parameters using the Nesterov Accelerated Gradient optimizer.\n    Uses a \"look-ahead\" approach to improve convergence by applying momentum before computing the gradient.\n    Args:\n        parameter: Current parameter value\n        grad_fn: Function that computes the gradient at a given position\n        velocity: Current velocity (momentum term)\n        learning_rate: Learning rate (default=0.01)\n        momentum: Momentum coefficient (default=0.9)\n    Returns:\n        tuple: (updated_parameter, updated_velocity)\n    \"\"\"\n    # Your code here\n    return np.round(parameter, 5), np.round(velocity, 5)","createdAt":"January 26, 2026 at 8:28:54 AM UTC-0500","title":"Nesterov Accelerated Gradient Optimizer","contributor":[{"profile_link":"https://github.com/mavleo96","name":"Vijayabharathi Murugan"}],"pytorch_test_cases":[{"test":"import torch\ndef gradient_function(x):\n    if x.dim() > 0:\n        n = len(x)\n        return x - torch.arange(n, dtype=x.dtype)\n    else:\n        return x - 0\nresult = nag_optimizer(torch.tensor(1.0), gradient_function, torch.tensor(0.5), 0.01, 0.9)\nprint((round(result[0].item(), 4), round(result[1].item(), 4)))","expected_output":"(0.5445, 0.4555)"},{"test":"import torch\ndef gradient_function(x):\n    if x.dim() > 0:\n        n = len(x)\n        return x - torch.arange(n, dtype=x.dtype)\n    else:\n        return x - 0\nresult = nag_optimizer(torch.tensor([1.0, 2.0]), gradient_function, torch.tensor([0.5, 1.0]), 0.01, 0.9)\nprint(([round(v, 4) for v in result[0].tolist()], [round(v, 4) for v in result[1].tolist()]))","expected_output":"([0.5445, 1.099], [0.4555, 0.901])"},{"test":"import torch\ndef gradient_function(x):\n    if x.dim() > 0:\n        n = len(x)\n        return x - torch.arange(n, dtype=x.dtype)\n    else:\n        return x - 0\nresult = nag_optimizer(torch.tensor([1.0, 2.0]), gradient_function, torch.tensor([0.5, 1.0]), 0.01, 0.0)\nprint(([round(v, 2) for v in result[0].tolist()], [round(v, 2) for v in result[1].tolist()]))","expected_output":"([0.99, 1.99], [0.01, 0.01])"},{"test":"import torch\ndef gradient_function(x):\n    if x.dim() > 0:\n        n = len(x)\n        return x - torch.arange(n, dtype=x.dtype)\n    else:\n        return x - 0\nresult = nag_optimizer(torch.tensor(0.9), gradient_function, torch.tensor(1.0), 0.01, 0.9)\nprint((round(result[0].item(), 1), round(result[1].item(), 1)))","expected_output":"(0.0, 0.9)"}],"pytorch_starter_code":"","learn_section":""}