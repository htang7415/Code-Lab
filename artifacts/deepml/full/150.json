{"tinygrad_test_cases":[{"test":"from tinygrad.tensor import Tensor\ndef gradient_function(x):\n    if len(x.shape) > 0 and x.shape[0] > 1:\n        n = x.shape[0]\n        return x - Tensor([float(i) for i in range(n)])\n    return x\nparam, vel = nag_optimizer(Tensor([1.0]), gradient_function, Tensor([0.5]), 0.01, 0.9)\nprint((round(param.item(), 4), round(vel.item(), 4)))","expected_output":"(0.5445, 0.4555)"},{"test":"from tinygrad.tensor import Tensor\ndef gradient_function(x):\n    if len(x.shape) > 0 and x.shape[0] > 1:\n        n = x.shape[0]\n        return x - Tensor([float(i) for i in range(n)])\n    return x\nparam, vel = nag_optimizer(Tensor([1.0, 2.0]), gradient_function, Tensor([0.5, 1.0]), 0.01, 0.9)\nprint(([round(v, 4) for v in param.numpy().tolist()], [round(v, 4) for v in vel.numpy().tolist()]))","expected_output":"([0.5445, 1.099], [0.4555, 0.901])"},{"test":"from tinygrad.tensor import Tensor\ndef gradient_function(x):\n    if len(x.shape) > 0 and x.shape[0] > 1:\n        n = x.shape[0]\n        return x - Tensor([float(i) for i in range(n)])\n    return x\nparam, vel = nag_optimizer(Tensor([1.0, 2.0]), gradient_function, Tensor([0.5, 1.0]), 0.01, 0.0)\nprint(([round(v, 2) for v in param.numpy().tolist()], [round(v, 2) for v in vel.numpy().tolist()]))","expected_output":"([0.99, 1.99], [0.01, 0.01])"},{"test":"from tinygrad.tensor import Tensor\ndef gradient_function(x):\n    if len(x.shape) > 0 and x.shape[0] > 1:\n        n = x.shape[0]\n        return x - Tensor([float(i) for i in range(n)])\n    return x\nparam, vel = nag_optimizer(Tensor([0.9]), gradient_function, Tensor([1.0]), 0.01, 0.9)\nprint((round(param.item(), 1), round(vel.item(), 1)))","expected_output":"(0.0, 0.9)"}],"description":"","embedding":[-0.021580899134278297,0.005292894784361124,0.04101743921637535,-0.01595667377114296,0.03536677733063698,0.06997661292552948,0.03365480154752731,0.009210759773850441,-0.05283522978425026,-0.0791088119149208,0.039143048226833344,0.00440613