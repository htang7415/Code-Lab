mall constant for numerical stability (default=1e-8)\n    Returns:\n        tuple: (updated_parameter, updated_m, updated_u)\n    \"\"\"\n\t# Your code here\n    return np.round(parameter, 5), np.round(m, 5), np.round(u, 5)","title":"Adamax Optimizer","learn_section":"","contributor":[{"profile_link":"https://github.com/mavleo96","name":"Vijayabharathi Murugan"}],"pytorch_test_cases":[{"test":"import torch\nresult = adamax_optimizer(1., 0.1, 1., 1., 1, 0.002, 0.9, 0.999, 1e-8)\nprint((result[0].item(), result[1].item(), result[2].item()))","expected_output":"(0.98178, 0.91, 0.999)"},{"test":"import torch\nresult = adamax_optimizer(torch.tensor([1., 2.]), torch.tensor([0.1, 0.2]), torch.tensor([1., 1.]), torch.tensor([1., 1.]), 1, 0.002, 0.9, 0.999, 1e-8)\nprint((result[0].tolist(), result[1].tolist(), result[2].tolist()))","expected_output":"([0.98178, 1.98158], [0.91, 0.92], [0.999, 0.999])"},{"test":"import torch\nresult = adamax_optimizer(torch.tensor([1., 2.]), torch.tensor([0.0, 0.0]), torch.tensor([0.1, 0.1]), torch.tensor([0., 0.]), 1, 0.002, 0.9, 0.999, 1e-8)\nprint((result[0].tolist(), result[1].tolist(), result[2].tolist()))","expected_output":"([-179999.00268, -179998.00268], [0.09, 0.09], [0.0, 0.0])"},{"test":"import torch\nresult = adamax_optimizer(1., 0.1, 1., 1., 1, 0.002, 0., 0., 1e-8)\nprint((result[0].item(), result[1].item(), result[2].item()))","expected_output":"(0.998, 0.1, 0.1)"}],"tinygrad_test_cases":[{"test":"from tinygrad.tensor import Tensor\nimport numpy as np\nresult = adamax_optimizer(Tensor([1.]), Tensor([0.1]), Tensor([1.]), Tensor([1.]), 1, 0.002, 0.9, 0.999, 1e-8)\nprint((float(result[0][0]), float(result[1][0]), float(result[2][0])))","expected_output":"(0.98178, 0.91, 0.999)"},{"test":"from tinygrad.tensor import Tensor\nimport numpy as np\nresult = adamax_optimizer(Tensor([1., 2.]), Tensor([0.1, 0.2]), Tensor([1., 1.]), Tensor([1., 1.]), 1, 0.002, 0.9, 0.999, 1e-8)\nprint((result[0], result[1], result[2]))","expected_output":"(array([0.98178, 1.98158]), array([0.91, 0.92]), array([0.999, 0.999]))"},{"test":"from tinygrad.tensor import Tensor\nimport numpy as np\nresult = adamax_optimizer(Tensor([1., 2.]), Tensor([0.0, 0.0]), Tensor([0.1, 0.1]), Tensor([0., 0.]), 1, 0.002, 0.9, 0.999, 1e-8)\nprint((result[0], result[1], result[2]))","expected_output":"(array([-179999., -179998.]), array([0.09, 0.09]), array([0., 0.]))"},{"test":"from tinygrad.tensor import Tensor\nimport numpy as np\nresult = adamax_optimizer(Tensor([1.]), Tensor([0.1]), Tensor([1.]), Tensor([1.]), 1, 0.002, 0., 0., 1e-8)\nprint((float(result[0][0]), float(result[1][0]), float(result[2][0])))","expected_output":"(0.998, 0.1, 0.1)"}],"pytorch_starter_code":""}