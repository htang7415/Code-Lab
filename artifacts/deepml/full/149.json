3882754612714052,-0.004031012766063213],"id":"149","tinygrad_difficulty":"medium","tinygrad_starter_code":"","test_cases":[{"test":"print(adadelta_optimizer(1., 0.5, 1., 1., 0.95, 1e-6))","expected_output":"(0.49035, 0.9625, 0.96299)"},{"test":"print(adadelta_optimizer(np.array([1., 2.]), np.array([0.1, 0.2]), np.array([1., 1.]), np.array([1., 1.]), 0.95, 1e-6))","expected_output":"(array([0.89743, 1.79502]), array([0.9505, 0.952]), array([0.95053, 0.9521]))"}],"difficulty":"medium","pytorch_difficulty":"medium","video":"","likes":"0","dislikes":"0","example":{"explanation":"The Adadelta optimizer computes updated values for the parameter, the running average of squared gradients (u), and the running average of squared parameter updates (v). With input values parameter=1.0, grad=0.1, u=1.0, v=1.0, and rho=0.95, the updated parameter becomes 0.89743.","input":"parameter = 1.0, grad = 0.1, u = 1.0, v = 1.0, rho = 0.95, epsilon = 1e-6","output":"(0.89743, 0.9505, 0.95053)"},"category":"Deep Learning","starter_code":"import numpy as np\n\ndef adadelta_optimizer(parameter, grad, u, v, rho=0.95, epsilon=1e-6):\n    \"\"\"\n    Update parameters using the AdaDelta optimizer.\n    AdaDelta is an extension of AdaGrad that seeks to reduce its aggressive,\n    monotonically decreasing learning rate.\n    Args:\n        parameter: Current parameter value\n        grad: Current gradient\n        u: Running average of squared gradients\n        v: Running average of squared parameter updates\n        rho: Decay rate for the moving average (default=0.95)\n        epsilon: Small constant for numerical stability (default=1e-6)\n    Returns:\n        tuple: (updated_parameter, updated_u, updated_v)\n    \"\"\"\n    # Your code here\n    return np.round(parameter, 5), np.round(u, 5), np.round(v, 5)","createdAt":"December 29, 2025 at 1:43:37 PM UTC-0500","title":"Adadelta Optimizer","contributor":[{"profile_link":"https://github.com/mavleo96","name":"Vijayabharathi Murugan"}],"pytorch_test_cases":[{"test":"import torch\nresult = adadelta_optimizer(torch.tensor(1.), torch.tensor(0.5), torch.tensor(1.), torch.tensor(1.), 0.95, 1e-6)\nprint((round(result[0].item(), 5), round(result[1].item(), 5), round(result[2].item(), 5)))","expected_output":"(0.49035, 0.9625, 0.96299)"},{"test":"import torch\nresult = adadelta_optimizer(torch.tensor([1., 2.]), torch.tensor([0.1, 0.2]), torch.tensor([1., 1.]), torch.tensor([1., 1.]), 0.95, 1e-6)\nprint(([round(x, 5) for x in result[0].tolist()], [round(x, 5) for x in result[1].tolist()], [round(x, 5) for x in result[2].tolist()]))","expected_output":"([0.89743, 1.79502], [0.9505, 0.952], [0.95053, 0.9521])"},{"test":"import torch\nresult = adadelta_optimizer(torch.tensor([1., 2.]), torch.tensor([0., 0.2]), torch.tensor([0., 1.]), torch.tensor([0., 1.]), 0.95, 1e-6)\nprint(([round(x, 5) for x in result[0].tolist()], [round(x, 5) for x in result[1].tolist()], [round(x, 5) for x in result[2].tolist()]))","expected_output":"([1.0, 1.79502], [0.0, 0.952], [0.0, 0.9521])"},{"test":"import torch\nresult = adadelta_optimizer(torch.tensor([1., 1.]), torch.tensor([1., 1.]), torch.tensor([10000., 1.]), torch.tensor([1., 1.]), 0.95, 1e-6)\nprint(([round(x, 5) for x in result[0].tolist()], [round(x, 5) for x in result[1].tolist()], [round(x, 5) for x in result[2].tolist()]))","expected_output":"([0.98974, 0.0], [9500.05, 1.0], [0.95001, 1.0])"},{"test":"import torch\nresult = adadelta_optimizer(torch.tensor(1.), torch.tensor(0.5), torch.tensor(1.), torch.tensor(1.), 0., 1e-6)\nprint((round(result[0].item(), 5), round(result[1].item(), 5), round(result[2].item(), 5)))","expected_output":"(0.0, 0.25, 1.0)"}],"pytorch_starter_code":"","learn_section":""}