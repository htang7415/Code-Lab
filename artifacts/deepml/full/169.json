rent time step\n      lr: float, learning rate\n      beta1: float, beta1 parameter\n      beta2: float, beta2 parameter\n      epsilon: float, small constant\n      weight_decay: float, weight decay coefficient\n    Returns:\n      w_new, m_new, v_new\n    \"\"\"\n    # Your code here\n    pass","title":"Implement AdamW Optimizer Step","learn_section":"","contributor":[{"profile_link":"https://github.com/moe18","name":"Moe Chabot"}],"pytorch_test_cases":[{"test":"import torch\nw = torch.tensor([1.0, 2.0])\ng = torch.tensor([0.1, -0.2])\nm = torch.zeros(2)\nv = torch.zeros(2)\nt = 1\nlr = 0.01\nbeta1 = 0.9\nbeta2 = 0.999\nepsilon = 1e-8\nweight_decay = 0.1\nw_new, m_new, v_new = adamw_update(w, g, m, v, t, lr, beta1, beta2, epsilon, weight_decay)\nprint([round(x, 4) for x in w_new.tolist()])","expected_output":"[0.989, 2.008]"},{"test":"import torch\nw = torch.tensor([1.5, -1.0])\ng = torch.tensor([-0.3, 0.5])\nm = torch.zeros(2)\nv = torch.zeros(2)\nt = 1\nlr = 0.005\nbeta1 = 0.9\nbeta2 = 0.999\nepsilon = 1e-8\nweight_decay = 0.01\nw_new, m_new, v_new = adamw_update(w, g, m, v, t, lr, beta1, beta2, epsilon, weight_decay)\nprint([round(x, 4) for x in w_new.tolist()])","expected_output":"[1.5049, -1.005]"},{"test":"import torch\nw = torch.tensor([1.0])\ng = torch.tensor([0.5])\nm = torch.zeros(1)\nv = torch.zeros(1)\nt = 1\nlr = 0.001\nbeta1 = 0.9\nbeta2 = 0.999\nepsilon = 1e-8\nweight_decay = 0.05\nw_new, m_new, v_new = adamw_update(w, g, m, v, t, lr, beta1, beta2, epsilon, weight_decay)\nprint([round(x, 4) for x in w_new.tolist()])","expected_output":"[0.999]"}],"tinygrad_test_cases":[{"test":"from tinygrad.tensor import Tensor\nimport numpy as np\nw = Tensor([1.0, 2.0])\ng = Tensor([0.1, -0.2])\nm = Tensor.zeros(2)\nv = Tensor.zeros(2)\nt = 1\nlr = 0.01\nbeta1 = 0.9\nbeta2 = 0.999\nepsilon = 1e-8\nweight_decay = 0.1\nw_new, m_new, v_new = adamw_update(w, g, m, v, t, lr, beta1, beta2, epsilon, weight_decay)\nprint([round(x, 4) for x in w_new.numpy().tolist()])","ex